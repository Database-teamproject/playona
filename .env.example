# =============================================
# Playona 환경변수 예시 — 값을 채워서 .env로 저장
# =============================================

# DB 비밀번호
DB_PASSWORD=your_db_password

# JWT 시크릿 (32자 이상 랜덤 문자열)
# 생성: openssl rand -base64 32
JWT_SECRET=your-random-secret-key-minimum-32-characters

# Spotify API
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# YouTube Data API v3
# https://console.cloud.google.com → API 및 서비스 → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# Kakao OAuth
# https://developers.kakao.com → 내 애플리케이션
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# Google OAuth
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
